# Optional generic JSON webhook for deploy/backup success and failure events.
RABBIT_QUANT_ALERT_WEBHOOK_URL=

# Keep the newest release images while preserving active and rollback images.
RABBIT_QUANT_IMAGE_RETENTION=5

# Local verified backup retention.
RABBIT_QUANT_BACKUP_DIR=/opt/rabbit-quant-backups
RABBIT_QUANT_BACKUP_RETENTION_DAYS=14
