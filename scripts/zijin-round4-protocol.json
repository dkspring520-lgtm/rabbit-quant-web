{
  "schemaVersion": 1,
  "experimentId": "zijin-round4-standard-quant",
  "round": 4,
  "status": "preregistered",
  "stock": {
    "code": "601899",
    "name": "紫金矿业"
  },
  "purpose": "验证可复现的紫金矿业日内做T假设，而不是把参数调到通过",
  "affectsV4": false,
  "automaticPromotion": false,
  "dataPolicy": {
    "selectionEnd": "2025-12-31",
    "sealedFinalBlindPeriod": {
      "start": "2026-01-01",
      "end": "2026-12-31",
      "allowedUse": "仅当滚动样本外门槛全部通过后，执行一次最终盲测",
      "allowParameterSelection": false,
      "allowFeatureSelection": false,
      "allowRepeatedInspection": false
    },
    "decisionTimestamp": "minute_t_close",
    "fillTimestamp": "minute_t_plus_1_open",
    "futureMinutesAllowedOnlyForOutcomeLabels": true,
    "embargoTradingDays": 1
  },
  "hypotheses": [
    {
      "id": "opening-repair",
      "name": "开盘缺口修复",
      "session": "09:30-10:30",
      "features": [
        "minuteOfDay",
        "gapPct",
        "openDeviationPct",
        "vwapBiasPct",
        "return3Pct",
        "ma5SlopePct",
        "volumeRatio",
        "peerBreadth3",
        "priorDayReturnPct",
        "priorZijinPeerAlphaPct"
      ]
    },
    {
      "id": "vwap-mean-reversion",
      "name": "VWAP偏离回归",
      "session": "09:35-14:30",
      "features": [
        "minuteOfDay",
        "vwapBiasPct",
        "vwapSlope5Pct",
        "priceZscore",
        "return3Pct",
        "volumeRatio",
        "atrPct",
        "intradayPosition",
        "reboundFromLowPct",
        "drawdownFromHighPct"
      ]
    },
    {
      "id": "peak-exhaustion",
      "name": "冲高衰竭",
      "session": "09:35-14:30",
      "features": [
        "minuteOfDay",
        "vwapBiasPct",
        "return3Pct",
        "return5Pct",
        "ma5SlopePct",
        "volumeRatio",
        "pullbackVolumeRatio",
        "intradayPosition",
        "drawdownFromHighPct",
        "peerBreadth3"
      ]
    },
    {
      "id": "sector-divergence",
      "name": "个股与板块背离",
      "session": "09:35-14:30",
      "features": [
        "minuteOfDay",
        "vwapBiasPct",
        "return3Pct",
        "peerReturn3Pct",
        "peerVwapBiasPct",
        "peerBreadth3",
        "goldReturn3Pct",
        "copperReturn3Pct",
        "zijinAlpha3Pct",
        "priorZijinPeerAlphaPct"
      ]
    }
  ],
  "validation": {
    "method": "anchored-walk-forward-quarterly",
    "minimumTrainingTradingDays": 252,
    "validationWindow": "calendar-quarter",
    "innerSelection": "chronological-only",
    "outerEvaluation": "quarterly-out-of-sample-only",
    "minimumOuterQuarters": 8,
    "minimumPositiveOuterQuarters": 6,
    "baseRoundTripCostPct": 0.12,
    "stressRoundTripCostPct": 0.18
  },
  "baselines": [
    {
      "id": "no-trade",
      "name": "不交易",
      "purpose": "确认策略承担风险后确实增加净收益"
    },
    {
      "id": "simple-vwap",
      "name": "简单VWAP规则",
      "purpose": "确认复杂模型优于可解释的基础规则"
    },
    {
      "id": "smart-t-v4",
      "name": "当前Smart-T V4",
      "purpose": "确认专属模型相对线上基准有稳定增益"
    }
  ],
  "multipleTesting": {
    "trialLedgerRequired": true,
    "probabilityOfBacktestOverfitting": {
      "method": "CSCV",
      "maximum": 0.2
    },
    "deflatedSharpe": {
      "minimumProbability": 0.95,
      "usesAllRecordedTrials": true
    }
  },
  "promotionGates": {
    "afterCostMeanNetPctGreaterThan": 0,
    "stressCostMeanNetPctAtLeast": 0,
    "minimumOutOfSampleWinRate": 0.65,
    "minimumPositiveQuarterRatio": 0.75,
    "mustBeatAllBaselines": true,
    "finalBlindTestRequired": true,
    "manualReviewRequired": true,
    "nextStage": "shadow-observation-only"
  },
  "trialLedger": {
    "format": "jsonl-append-only",
    "requiredFields": [
      "trialId",
      "hypothesisId",
      "configHash",
      "sourceCommit",
      "createdAt",
      "trainingRange",
      "validationRange",
      "featureNames",
      "parameters",
      "baseCostMetrics",
      "stressCostMetrics",
      "baselineMetrics",
      "selectionDecision"
    ]
  },
  "shadowReconciliation": {
    "continuousSimulationRequired": true,
    "requiredFields": [
      "signalId",
      "hypothesisId",
      "theoreticalDecisionAt",
      "theoreticalFillAt",
      "theoreticalFillPrice",
      "simulatedFillAt",
      "simulatedFillPrice",
      "quantity",
      "fees",
      "slippagePct",
      "matched",
      "rejectionReason"
    ],
    "reconcileEverySignal": true,
    "unmatchedSignalsCountAsFailures": true
  },
  "stageOrder": [
    "preregistered",
    "rolling-out-of-sample",
    "final-2026-blind",
    "manual-review",
    "shadow-observation"
  ]
}
